# ── NomasHumedades — Backend .env ────────────────────────────────────────────
# Copia este archivo como .env y rellena los valores reales.
# NUNCA subas .env a Git.

# ── JWT (genera con: python -c "import secrets; print(secrets.token_hex(32))")
SECRET_KEY=CAMBIA_ESTO_CLAVE_ALEATORIA_SEGURA

# ── Base de datos ─────────────────────────────────────────────────────────────
DATABASE_URL=sqlite:///./nomashumedades.db

# ── Admin inicial ─────────────────────────────────────────────────────────────
ADMIN_EMAIL=admin@nomashumedades.com
ADMIN_PASSWORD=CAMBIA_ESTA_CONTRASEÑA

# ── CORS (dominio del frontend, sin barra final) ──────────────────────────────
ALLOWED_ORIGINS=https://nomashumedades.com

# ── Email SMTP ────────────────────────────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=tu@gmail.com
SMTP_PASSWORD=contraseña_de_aplicacion_gmail
EMAIL_FROM=NomasHumedades <tu@gmail.com>
EMAIL_ADMIN=admin@nomashumedades.com

# ── Datos de la tienda ────────────────────────────────────────────────────────
TIENDA_NOMBRE=NomasHumedades
TIENDA_TELEFONO=+34 956 XXX XXX
IBAN=ES00 0000 0000 0000 0000 0000

# ── SumUp ─────────────────────────────────────────────────────────────────────
SUMUP_ENABLED=false
SUMUP_API_KEY=sk_live_XXXXXXXXXXXXXXXXXXXXXX
SUMUP_MERCHANT_CODE=MXXXXXXX
SUMUP_WEBHOOK_SECRET=
BACKEND_URL=https://api.nomashumedades.com
FRONTEND_URL=https://nomashumedades.com

# ── PDFs de catálogos (relativo a backend/) ───────────────────────────────────
MARCAS_DIR=catalogos
MARCAS_FALLBACK_DIR=../../tienda-online/marcas
